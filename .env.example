# =============================================================================
# Living Photos — environment template
# Copy to .env.local for dev. All paid keys can be blank in MOCK_MODE.
# =============================================================================

# -- Mode --------------------------------------------------------------------
# Set to "true" to run end-to-end without any paid API keys (mock adapters).
# Set to "false" to use real APIs (requires the keys below).
MOCK_MODE=true

# -- Public app --------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Database (Neon Postgres via @neondatabase/serverless) -------------------
# In MOCK_MODE we don't read the DB during tests, but the URL is still validated.
DATABASE_URL=postgres://placeholder:placeholder@localhost:5432/livingphotos

# -- Storage (Vercel Blob) ---------------------------------------------------
# Stub OK in MOCK_MODE; the mock adapter returns fixture URLs.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_placeholder

# -- Inngest (background jobs) -----------------------------------------------
# Local dev uses the inngest-cli; leave these blank.
# In prod set INNGEST_EVENT_KEY + INNGEST_SIGNING_KEY from Inngest dashboard.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# -- World Labs Marble (.spz environment generation) -------------------------
WORLD_LABS_API_KEY=

# -- FAL (Hunyuan3D mesh generation) ----------------------------------------
FAL_KEY=

# -- ElevenLabs (voice clone + SFX + narration) -----------------------------
ELEVENLABS_API_KEY=

# -- Stripe (payments) -------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# -- Auth (Clerk) ------------------------------------------------------------
# Deferred — V1 is anonymous-first with email captured at Checkout.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# -- Observability (Sentry + PostHog) ---------------------------------------
# No-op in dev when blank.
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -- Email (Resend) ----------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL="Living Photos <hello@livingphotos.app>"
