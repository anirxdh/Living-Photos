{
  "name": "living-photos",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "next dev --turbo",
    "dev:inngest": "npx inngest-cli@latest dev -u http://localhost:3000/api/inngest",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm typecheck && pnpm lint && pnpm test && pnpm test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.47.0",
    "@fal-ai/client": "^1.6.0",
    "@neondatabase/serverless": "^1.0.1",
    "@sentry/nextjs": "^9.0.0",
    "@react-three/drei": "^10.5.0",
    "@react-three/fiber": "^9.6.1",
    "@vercel/blob": "^1.0.0",
    "@vercel/og": "^0.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.39.0",
    "inngest": "^3.32.0",
    "lucide-react": "^0.469.0",
    "nanoid": "^5.0.9",
    "next": "15.5.0",
    "posthog-js": "^1.205.0",
    "posthog-node": "^4.5.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-dropzone": "^14.3.5",
    "resend": "^4.0.1",
    "sonner": "^1.7.1",
    "stripe": "^22.1.0",
    "tailwind-merge": "^2.6.0",
    "three": "^0.178.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.178.0",
    "@vitest/coverage-v8": "^2.1.8",
    "@vitest/ui": "^2.1.8",
    "drizzle-kit": "^0.30.0",
    "happy-dom": "^16.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
